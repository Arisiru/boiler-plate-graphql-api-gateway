{
  "name": "GraphQL API Wrapper",
  "version": "0.0.2",
  "description": "The GraphQL end point as an API Gateway",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "dev": "ts-node server.ts",
    "prestart": "npm run build",
    "test": "jest",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "prettier": "prettier --write '**/*.{ts,js,json,graphql}'"
  },
  "repository": {
    "type": "git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@apollo/datasource-rest": "^6.0.0",
    "@apollo/server": "^4.11.0",
    "@graphql-tools/schema": "^10.0.0",
    "@okta/jwt-verifier": "^3.0.0",
    "dotenv": "^16.4.0",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@eslint/js": "^9.0.0",
    "globals": "^15.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^4.2.5",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^10.0.8",
    "prettier": "^3.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!**/*.test.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 42
      }
    },
    "reporters": [
      "default",
      "jest-junit"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "git diff HEAD --quiet && npm test"
    }
  },
  "lint-staged": {
    "*.+(ts|js|json|graphql|md)": [
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 90,
    "bracketSpacing": true,
    "trailingComma": "es5",
    "singleQuote": true
  }
}
